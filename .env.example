# Copy this file to `.env` and fill in your real values.
# `.env` is gitignored — never commit real keys.

# Your Anthropic key — powers the agent brain (agent_brain.py)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# Your Vocal Bridge agent/account key — from the agent's Develop tab or Dashboard > API Keys
VOCAL_BRIDGE_API_KEY=vb_xxxxxxxxxxxxxxxx

# Which Claude model powers the brain. Default (if unset) is claude-haiku-4-5 —
# fast + cheap, good for voice. Use claude-sonnet-4-6 or claude-opus-4-8 for smarter
# tool decisions at higher latency/cost.
BRAIN_MODEL=claude-haiku-4-5

# Your Sabre application User ID (My Account > Applications). Only needed to call
# REAL Sabre; the mock ignores it. Format: V1:<id>:DEVCENTER:EXT
SABRE_USER_ID=V1:YOUR_USER_ID:DEVCENTER:EXT

# Where the voice agent lives, and where Sabre calls go
VOCAL_BRIDGE_URL=https://vocalbridgeai.com
SABRE_BASE=http://localhost:8080
